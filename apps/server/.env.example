# 复制为 .env 并填入真实值;.env 已在 .gitignore 中,不会被提交。

# ========== 必填(生产环境)==========

# JWT 签名密钥 —— 任意长字符串,建议 ≥32 字节随机值
# 生成命令: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# ========== 可选 ==========

# HTTP 端口,默认 3000。Railway 等平台会自动注入 PORT,此处无需配置
PORT=3000

# SQLite 数据库文件路径
# - 未设置时使用 apps/server/data/expense.db(本地开发默认)
# - Railway 等部署平台请指向 Volume 挂载点,例如 /app/data/expense.db
# - 启动时若目录不存在会自动创建
# DATABASE_PATH=/app/data/expense.db

# 跨域白名单(逗号分隔),仅在 NODE_ENV=production 时生效
# - 未设置或为空时放开所有来源(便于首次部署调试)
# - 示例: ALLOWED_ORIGINS=https://app.example.com,https://www.example.com
# ALLOWED_ORIGINS=

# OpenAI API Key —— 设置后启用 AI 增强解析(未设置时仅使用规则引擎)
# 获取地址: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# OpenAI 模型,默认 gpt-4.1-nano
# OPENAI_MODEL=gpt-4.1-nano
